# Package name of the modified Conceal Clash Meta For Android APK.
CMFA_PACKAGE=com.github.ychaiyi.conceal.clash.meta.for.android

# Root proxy service class in the modified APK.
CMFA_SERVICE=com.github.kr328.clash.service.RootProxyService

# Ports injected by the modified native config when root mode is enabled.
CMFA_REDIR_PORT=7892
CMFA_TPROXY_PORT=7893
CMFA_DNS_PORT=1053

# auto prefers TPROXY when available and falls back to REDIR TCP/DNS.
CMFA_PROXY_MODE=auto

# TProxy policy routing settings.
CMFA_MARK=0x2d0
CMFA_ROUTE_TABLE=20230
CMFA_RULE_PREF=10030

# Set to 0 if the device kernel or ROM breaks ip6tables TPROXY.
CMFA_ENABLE_IPV6=1

# Extra destination CIDRs to bypass, separated by spaces.
CMFA_EXTRA_BYPASS_V4=
CMFA_EXTRA_BYPASS_V6=
